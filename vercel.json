{
  "crons": [
    {
      "path": "/api/cron/generate",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/publish",
      "schedule": "0 22 * * *"
    }
  ],
  "functions": {
    "app/api/generate/route.ts": { "maxDuration": 300 },
    "app/api/bulk-generate/route.ts": { "maxDuration": 300 },
    "app/api/cron/generate/route.ts": { "maxDuration": 300 },
    "app/api/cron/publish/route.ts": { "maxDuration": 300 }
  }
}
